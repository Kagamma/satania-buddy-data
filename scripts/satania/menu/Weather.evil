#include 'data/scripts/libs/weather.evil'

lat = 35.6895
lng = 139.69171
units = 'metric'
api_key = 'b97d0e1a370bd2542e2ad62a17fc3d49'

data = weather_get(lat, lng, units, api_key)

talk(string_format('Current weather at <font color="#ff0000">{0}</font> is <font color="#0000ff">{1}</font>, with temperature of <font color="#0000ff">{2}C</font> and humidity of <font color="#0000ff">{3}%</font>', [data[0], data[1], data[2], data[3]]))
